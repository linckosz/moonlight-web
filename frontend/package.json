{
  "name": "moonlight-web-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Frontend tooling for Moonlight-Web (Vanilla JS, no build).",
  "scripts": {
    "lint": "eslint js scripts",
    "lint:fix": "eslint js scripts --fix",
    "format": "prettier --check \"js/**/*.js\" \"scripts/**/*.{js,cjs}\"",
    "format:fix": "prettier --write \"js/**/*.js\" \"scripts/**/*.{js,cjs}\"",
    "typecheck": "tsc --noEmit",
    "check": "npm run format && npm run lint"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
