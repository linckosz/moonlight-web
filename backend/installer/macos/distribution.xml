<?xml version="1.0" encoding="utf-8"?>
<!--
  MoonlightWeb, macOS product archive (productbuild distribution).

  Kept as close as possible to what `productbuild` synthesizes: Installer.app is
  strict and barely documented, and extra elements are known to break it. In
  particular the <domains> element (combined with rootVolumeOnly) made the
  Install phase fail with "there was no software found to install"; system-wide
  install now relies on rootVolumeOnly alone.

  The custom "Sunshine" pane (credentials, Internet toggle, download progress)
  is an InstallerPlugin loaded through the plugins directory; see
  plugins/InstallerSections.plist. Sunshine install + credentials happen in the
  component's postinstall script (root); pairing + the public A-record are done
  by MoonlightWeb.app on first launch (Provisioning::applyOnce), which is why
  they are NOT installer panes.

  Built by backend/installer/macos/build-pkg.sh (and the release.yml macos job),
  which substitutes @MW_VERSION@ and runs productbuild with this distribution
  plus the resources and plugins directories.
-->
<installer-gui-script minSpecVersion="1">
    <title>MoonlightWeb</title>
    <organization>com.moonlightweb</organization>

    <!-- HTML shown on the Introduction / License / Summary panes. -->
    <welcome file="welcome.html" mime-type="text/html"/>
    <license file="license.html" mime-type="text/html"/>
    <conclusion file="conclusion.html" mime-type="text/html"/>

    <!-- System-wide install onto the boot volume; the custom panes still show
         (customize="never" only hides the package-selection list). -->
    <options customize="never" require-scripts="false" rootVolumeOnly="true"
             hostArchitectures="arm64"/>

    <choices-outline>
        <line choice="default">
            <line choice="com.moonlightweb.server"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="com.moonlightweb.server" visible="false">
        <pkg-ref id="com.moonlightweb.server"/>
    </choice>

    <pkg-ref id="com.moonlightweb.server" version="@MW_VERSION@" onConclusion="none">MoonlightWeb-component.pkg</pkg-ref>
</installer-gui-script>
