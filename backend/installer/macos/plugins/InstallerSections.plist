<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Section order for Installer.app. The built-in section names are fixed; the
  custom entry "Sunshine" is the InstallerSectionTitle of MoonlightWebInstaller
  .bundle (see the plugin's Info.plist). That one section chains two panes
  internally (credentials -> download progress) via -nextPane, so a single entry
  here covers both. This file sits alongside the .bundle in the productbuild
  --plugins directory.
-->
<plist version="1.0">
<dict>
    <key>SectionOrder</key>
    <array>
        <string>Introduction</string>
        <string>ReadMe</string>
        <string>License</string>
        <string>Target</string>
        <string>PackageSelection</string>
        <string>Sunshine</string>
        <string>Install</string>
        <string>FinishUp</string>
    </array>
</dict>
</plist>
