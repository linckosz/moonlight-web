# Caddy — HTTPS for the public-facing parts of the DNS stack:
#   - api.{MW_DOMAIN}        reverse proxy to the PowerDNS REST API
#   - {MW_DOMAIN} + www.*    static presentation website (./site)
#
# Rendered at boot by the caddy entrypoint:
#   @MW_DOMAIN@       → parent domain
#   @TLS_LINE@        → empty for automatic Let's Encrypt, or a "tls ..."
#                       directive when the user supplies cert files / ACME email.
#   @SITE_TLS_LINE@   → same, but never the api-only cert: just an ACME email
#                       (or empty) so the apex/www always get their own cert.
#
# rate_limit comes from the caddy-ratelimit plugin (built into this image via
# xcaddy) and throttles API brute-force / abuse per client IP.

{
	order rate_limit before reverse_proxy
}

api.@MW_DOMAIN@ {
	@TLS_LINE@
	rate_limit {
		zone mw_api {
			key {remote_host}
			events 60
			window 1m
		}
	}
	# pdns = the PowerDNS service on the compose network (API on :8081).
	reverse_proxy pdns:8081
}

# Analytics dashboard — self-hosted Umami (privacy-friendly, cookieless).
# Serves both the tracker script (/script.js) and the admin dashboard.
stats.@MW_DOMAIN@ {
	@SITE_TLS_LINE@
	encode zstd gzip
	reverse_proxy umami:3000
}

# Presentation website — apex + www both serve the static ./site folder.
@MW_DOMAIN@, www.@MW_DOMAIN@ {
	@SITE_TLS_LINE@
	# Redirect bare/www visitors to the canonical apex (drop the www).
	@www host www.@MW_DOMAIN@
	redir @www https://@MW_DOMAIN@{uri} permanent
	encode zstd gzip
	root * /srv/site
	file_server
}
