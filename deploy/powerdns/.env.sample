# Moonlight-Web — self-hosted PowerDNS + Caddy (Docker) configuration.
# Copy to ".env" in this directory, then edit. NEVER commit the real .env.

# Parent domain you own and host on this PowerDNS server.
# Each Moonlight-Web instance gets a random subdomain "{uniqueId}.{MW_DOMAIN}".
MW_DOMAIN=example.top

# Public IPv4 of THIS DNS box. Used for the apex A record, the ns1/ns2 glue
# and the api.{MW_DOMAIN} host. Must match what you register at your registrar.
MW_PUBLIC_IP=203.0.113.10

# PowerDNS REST API key (X-API-Key). SECRET — generate a long random value, e.g.
#   openssl rand -hex 24
# Use the SAME value as MW_PDNS_TOKEN in the Moonlight-Web server .env.
MW_PDNS_API_KEY=change-me-to-a-long-random-secret

# ── TLS for the API (api.{MW_DOMAIN}) ────────────────────────────────────────
# Two options, user-supplied files take PRIORITY:
#
# Option A (default): leave MW_TLS_CERT / MW_TLS_KEY empty → Caddy obtains and
# auto-renews a Let's Encrypt certificate. MW_TLS_EMAIL is optional but
# recommended (expiry notices from the CA).
MW_TLS_EMAIL=

# Option B: bring your own cert. Put the files under ./certs (bind-mounted to
# /certs in the container) and point these at the in-container paths. When BOTH
# are set they override Let's Encrypt entirely.
MW_TLS_CERT=
MW_TLS_KEY=
# Example:
#   MW_TLS_CERT=/certs/fullchain.pem
#   MW_TLS_KEY=/certs/privkey.pem
