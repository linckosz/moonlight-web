# Temp
*.log
/tmp/

# Certificates (generated at runtime)
backend/certs/

# Build cache
backend/.cache/

# Agent session results
.claude/results/

# Local dev config (committed once, then ignored)
.moonlight-web-dev

# Private key embedding (never committed)
.env

# Node tooling (frontend lint/format/typecheck)
node_modules/

# Test coverage reports (generated)
frontend/coverage/
backend/tests/cov.xml
backend/tests/covhtml/

# clang-tidy compilation database (generated, machine-absolute paths)
backend/compile_commands.json

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Claude Code / AI agent files (kept on disk, never pushed)
.claude/
CLAUDE.md

# Graphify
graphify-out/

# ── Local debug / scratch helpers (kept on disk, never pushed) ──
# Root-level build & debug scripts + scratch output (none belong in the repo)
/*.bat
/*.cmd
/*.ps1
/*.sh
/*.txt
/_explore.js
/list-files-output.md

# Backend debug/build scratch — keep only the dependency build scripts
backend/*.bat
backend/*.cmd
backend/*.ps1
backend/*.sh
