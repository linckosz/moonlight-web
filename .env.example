# MoonlightWeb — environment configuration (copy to .env, never commit .env)
#
# .env is loaded at startup into the process environment (see main.cpp:loadEnvFile)
# and is also read at build time for the embedded fallback cert (CMakeLists.txt).
# All values below are OPTIONAL: without them the server runs in LAN-only mode
# with a self-signed certificate. They are only needed for "Internet Access"
# (public domain + automatic TLS via a self-hosted PowerDNS + ACME).

# ── Public domain (Internet Access) ─────────────────────────────────────────
# Parent domain you own and host on your PowerDNS server. Each instance gets a
# random subdomain "{uniqueId}.{MW_DOMAIN}". Drives the PowerDNS zone name too.
MW_DOMAIN=example.top

# Full PowerDNS API base URL. The API can live on a DIFFERENT domain than the
# app (e.g. a dedicated DNS box), so set the complete URL here. Optional —
# defaults to "https://api.{MW_DOMAIN}/api/v1/servers/localhost" when unset.
MW_PDNS_URL=https://api.example.top/api/v1/servers/localhost

# PowerDNS API key (X-API-Key). Required for A/TXT record management.
# This is a SECRET — keep it out of version control.
MW_PDNS_TOKEN=your-powerdns-api-key

# ── TLS — two options ───────────────────────────────────────────────────────
#
# Option A (default, recommended): automatic certificate via ACME.
#   Nothing to set here beyond MW_DOMAIN + MW_PDNS_TOKEN above. The server
#   obtains and auto-renews a real cert (DNS-01 challenge). With the ZeroSSL
#   EAB credentials below it issues from ZeroSSL; otherwise from Let's Encrypt.
#
# Option B: bring your own domain + your own certificate files.
#   Do NOT set anything here. Instead, in settings.json set:
#     "domain":   "your.fqdn.example"            (your own FQDN)
#     "cert_pem": "C:/path/to/fullchain.pem"     (file path)
#     "cert_key": "C:/path/to/key.pem"           (file path)
#   cert_pem/cert_key accept either a file path or an env var name.

# ACME directory URL. Optional. Defaults to Let's Encrypt, unless ZeroSSL EAB
# credentials below are set (then defaults to ZeroSSL DV90).
#MW_ACME_DIRECTORY=https://acme-v02.api.letsencrypt.org/directory

# ZeroSSL External Account Binding (optional — only if you issue from ZeroSSL
# instead of Let's Encrypt; both values are SECRETS).
#MW_ZEROSSL_EAB_KID=your-eab-kid
#MW_ZEROSSL_EAB_HMAC=your-eab-hmac
